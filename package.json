{
  "name": "chatgpt-bridge",
  "version": "1.0.0",
  "description": "Bridge between ChatGPT web version and Hermes Agent",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:xvfb": "HEADLESS=false xvfb-run --auto-servernum --server-args=\"-screen 0 1920x1080x24\" node server.js",
    "login": "HEADLESS=false node src/login.js",
    "login:xvfb": "HEADLESS=false xvfb-run --auto-servernum --server-args=\"-screen 0 1920x1080x24\" node src/login.js",
    "login:user": "HEADLESS=false node src/login.js --user",
    "dev": "node --watch server.js",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "marked": "^11.1.0",
    "node-fetch": "^2.7.0",
    "patchright": "^1.61.1",
    "playwright": "^1.41.0",
    "ws": "^8.16.0"
  }
}
