# ChatGPT Bridge — Environment Configuration
# Copy to .env and adjust as needed.

# HTTP/WS port
PORT=3400

# Headless by default. Set to false only for first-time login (npm run login).
HEADLESS=true

# Log level: trace|debug|info|warn|error (default: info)
LOG_LEVEL=info

# ── Multi-user mode ────────────────────────────────────────────────
# To enable multi-user mode, create users.json (see users.json.example).
# Each user gets their own browser-data/<userId>/ directory and ChatGPT account.
# In multi-user mode, API requests must include x-api-key header.

# Maximum number of concurrent browser contexts (default: 5).
# Each context uses ~150MB RAM.
# MAX_CONCURRENT_USERS=5

# ── Security ───────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (default: * for dev).
# ALLOWED_ORIGINS=https://yourapp.com,https://admin.yourapp.com

# Set to true to expose /api/debug/* endpoints (default: false).
# ENABLE_DEBUG=false

# ── Timeouts ───────────────────────────────────────────────────────
# Session navigation timeout (ms)
SESSION_TIMEOUT=30000
# Response wait timeout (ms)
RESPONSE_TIMEOUT=300000

# ── Docker ─────────────────────────────────────────────────────────
# When running in Docker, these are set in docker-compose.yml:
#   init: true       — PID 1 zombie reaping + signal forwarding
#   ipc: host        — Chromium shared memory (prevents OOM)
#   shm_size: 2gb    — Chromium needs lots of shared memory
#
# Login in Docker (headful, one-off):
#   docker compose run --rm login-user alice
#
# Or without Docker:
#   npm run login -- --user alice
